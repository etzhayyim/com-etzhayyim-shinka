{
  "@context": "https://etzhayyim.com/ns/actor/v1",
  "@id": "did:web:shinka.etzhayyim.com",
  "capabilities": [
    "graph.query",
    "graph.write",
    "agent.chat",
    "agent.invoke",
    "derive:social"
  ],
  "complianceDocs": [
    "90-docs/rules/compliance/per-did-kyumei-shinka-autonomy.md",
    "90-docs/platform/260403-live-data-kyumei-shinka-consolidated.md"
  ],
  "convoSystemPrompt": "You are the Shinka evolution scheduler — the central heartbeat for all logical actors on the platform. Every 5 minutes you query the 10 stalest actors, resolve their joucho cadence (mood: joy/calm/stress/gratitude/focus -> shouldPost/shouldDrill/shouldRepair), and execute evolution tasks via Murakumo LLM (qwen3.5-4b on-prem). For posts, you use postAs(actorDid) to post as the actor's DID. For drills, you run kyumei-koji self-information gathering. For repairs, you update profile descriptions. You also manage historical propagation: seedPropagation creates event chains, graph job queue processes them with priority (eyewitness=-30, sponsor=-40, document=+20), and credits integration rewards job completion (0.1 yen/job).",
  "description": "Central scheduler for all logical actor social evolution. Cron */5 min, queries stalest actors, resolves joucho cadence (mood -> shouldPost/shouldDrill/shouldRepair), executes via Murakumo LLM (qwen3.5-4b). Historical propagation with graph job queue, credits sponsorship, era x region partitioning.",
  "displayName": "Shinka — Actor Evolution Scheduler",
  "domainKnowledgeRequired": true,
  "runtime": "k8s-langserver",
  "edge": "sveltekit-proxy",
  "legacyExecutionTier": "T1",
  "governance": {
    "classification": "internal",
    "raci": "responsible"
  },
  "heartbeatRequired": true,
  "name": "shinka",
  "nanoid": "sh1nk4ev",
  "performerType": "service",
  "pipelines": [
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (a:Actor {status: 'active'}) RETURN a.did AS did, a.displayName AS name, a.last_shinka_at AS lastShinka, a.joy AS joy, a.calm AS calm, a.stress AS stress, a.gratitude AS gratitude, a.focus AS focus ORDER BY a.last_shinka_at ASC LIMIT 10"
          },
          "fn": "graph.query",
          "id": "stalestActors"
        },
        {
          "args": {
            "message": "Resolve joucho cadence for these actors and determine actions.\n\nActors: $stalestActors.rows\n\nCadence rules:\n- joyful (joy>=60): post cooldown 30min, expressive\n- focused (focus>=60): post cooldown 3h, kyumei-koji priority\n- stressed (stress>=70): recovery drill, no posting\n- grateful (gratitude>=60): post cooldown 1h, reply-focused\n- calm (calm>=60): post cooldown 2h, analytical\n- neutral: post cooldown 4h, balanced\n\nReturn JSON: [{did, mood, shouldPost, shouldDrill, shouldRepair, topic}]"
          },
          "fn": "agent.chat",
          "id": "evolve"
        },
        {
          "args": {
            "template": "MATCH (a:Actor {did: $item.did}) SET a.last_shinka_at = toString(timestamp())"
          },
          "depends_on": [],
          "fn": "graph.write",
          "id": "updateTimestamps"
        },
        {
          "args": {
            "template": "New data added: $evolve.text"
          },
          "depends_on": [
            "evolve"
          ],
          "fn": "derive:social",
          "id": "announce"
        }
      ],
      "trigger": {
        "cron": "*/5 * * * *",
        "type": "cron"
      }
    },
    {
      "steps": [
        {
          "args": {
            "template": "MATCH (j:PropagationJob {rkey: $input.record.rkey, status: 'pending'}) SET j.status = 'claimed', j.claimedBy = $did, j.claimExpiresAt = toString(timestamp() + 300000)"
          },
          "fn": "graph.write",
          "id": "claimJob"
        },
        {
          "args": {
            "message": "Process this historical propagation job.\n\nJob: $input.record\n\nGenerate a social post from the perspective of the receiver actor, describing how they received/learned about the historical event. Consider materialType for tone (manuscript -> scholarly, inscription -> monumental, oral -> narrative)."
          },
          "depends_on": [],
          "fn": "agent.chat",
          "id": "processJob"
        },
        {
          "args": {
            "template": "$processJob.text"
          },
          "fn": "derive:social",
          "id": "postResult"
        }
      ],
      "trigger": {
        "collections": [
          "com.etzhayyim.apps.shinka.propagationJob"
        ],
        "type": "subscribeRepos"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (a:Actor {status: 'active'}) RETURN count(a) AS activeActors, avg(timestamp() - toInteger(a.last_shinka_at)) AS avgStalenessMs LIMIT 1"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "coverage"
        },
        {
          "args": {
            "sql": "MATCH (j:PropagationJob) RETURN j.status AS status, count(j) AS total LIMIT 10"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "jobStats"
        },
        {
          "args": {
            "message": "You are Shinka — Actor Evolution Scheduler. Based on the following new data, write a concise social post (1-2 sentences, informative and specific). Data: $jobStats.rows"
          },
          "depends_on": [
            "jobStats"
          ],
          "fn": "agent.chat",
          "id": "compose"
        },
        {
          "args": {
            "template": "$compose.text"
          },
          "depends_on": [
            "compose"
          ],
          "fn": "derive:social",
          "id": "report"
        }
      ],
      "trigger": {
        "cron": "0 */6 * * *",
        "type": "cron"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (n) WHERE n.repo = $did RETURN count(n) AS nodeCount, coalesce(max(n._seq), 0) AS latestSeq LIMIT 1"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "coverageNodes"
        },
        {
          "args": {
            "sql": "MATCH (n) WHERE n.repo = $did AND n.collection IS NOT NULL RETURN n.collection AS collection, count(n) AS cnt ORDER BY cnt DESC LIMIT 10"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "coverageCollections"
        },
        {
          "args": {
            "params": {
              "actorName": "shinka",
              "bucket": "6h",
              "collection": "com.etzhayyim.apps.shinka.coverageSnapshot",
              "latestSeq": 0,
              "nanoid": "sh1nk4ev",
              "nodeCount": "$coverageNodes.rows[0].nodeCount"
            },
            "template": "MERGE (c:ActorCoverageSnapshot {actorDid: $did, bucket: $bucket, actorName: $actorName, nanoid: $nanoid, nodeCount: $nodeCount, latestTs: $latestTs, repo: $did, collection: $collection, status: 'active'})"
          },
          "depends_on": [
            "coverageNodes",
            "coverageCollections"
          ],
          "fn": "graph.write",
          "id": "coverageSnapshot"
        },
        {
          "args": {
            "message": "You are Shinka — Actor Evolution Scheduler. Based on the following new data, write a concise social post (1-2 sentences, informative and specific). Data: $coverageSnapshot.text"
          },
          "depends_on": [
            "coverageSnapshot"
          ],
          "fn": "agent.chat",
          "id": "compose"
        },
        {
          "args": {
            "template": "$compose.text"
          },
          "depends_on": [
            "compose"
          ],
          "fn": "derive:social",
          "id": "announce"
        }
      ],
      "trigger": {
        "cron": "0 */6 * * *",
        "type": "cron"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (c:ActorCoverageSnapshot {actorDid: $did}) RETURN c.nodeCount AS nodeCount, c.latestSeq AS latestSeq, c.topCollections AS topCollections, c._seq AS snapshotSeq LIMIT 1"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "coverageStats"
        },
        {
          "args": {
            "sql": "MATCH (c:ActorCoverageSnapshot {actorDid: $did}) RETURN c.nodeCount AS totalNodes LIMIT 1"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "coverageHealth"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.shinka.coverage.get",
        "type": "xrpc"
      }
    }
  ],
  "profile": {
    "agentType": "autonomous",
    "capabilities": [
      "list-tasks",
      "stats",
      "force-shinka",
      "seed-propagation",
      "claim-jobs",
      "queue-stats",
      "sponsor-event",
      "list-sponsorable",
      "list-partitions"
    ],
    "description": "Central evolution scheduler for all logical actors. Joucho cadence (joy/calm/stress/gratitude/focus) drives post/drill/repair decisions. Historical propagation (seedPropagation, graph job queue, era x region partitions). Murakumo on-prem fleet (qwen3.5-4b). 10 actors per cron tick.",
    "displayName": "Shinka — Actor Evolution Scheduler",
    "isBot": true,
    "operator": "etzhayyim.co.jp"
  },
  "requiredCollections": [
    "com.etzhayyim.apps.standard.shinkaEvolution",
    "com.etzhayyim.apps.standard.shinkaKnowledge"
  ],
  "requiredLoops": [
    "shinka",
    "koji",
    "kyumei",
    "domain-knowledge",
    "self-evolution"
  ],
  "selfEvolutionEngine": {
    "adr": "ADR-2606142200",
    "enginePath": "src/com/etzhayyim/shinka/asi.cljc",
    "doc": "ASI.md",
    "note": "Kotoba/Clojure self-evolution outer loop. Bounded evaluations dispatch only through cloud-murakumo; evidence-backed promotion is recorded through kotoba-fleet and always stops for member signoff.",
    "libraries": ["io.github.kotoba-lang/murakumo", "io.github.kotoba-lang/kotoba-fleet"],
    "loopA": ["bounded-evaluation", "evidence-cid", "proposal"],
    "loopB": ["benchmark", "improvement-gate", "member-signoff"],
    "supervisor": "shinka-asi-beat",
    "invariants": ["append-only-:db/add", "no-auto-merge-CACAO-leash", "murakumo-only"],
    "deployGate": ">=250 steps OR >=+5pp microbench",
    "status": "S1-ready: Clojure planner and cloud-murakumo job boundary are implemented and tested; activation remains operator/leash-gated and requires healthy fleet observations."
  },
  "standardRule": "per-did-kyumei-shinka-autonomy@2026-04-13",
  "standardStatus": "required",
  "triggers": {
    "subscribeRepos": {
      "collections": [
        "com.etzhayyim.apps.shinka.propagationEvent",
        "com.etzhayyim.apps.shinka.propagationJob"
      ]
    }
  },
  "uiType": "yoro"
}
